class Solution {
  public:
    // Function to count the frequency of all elements from 1 to N in the array.
    vector<int> frequencyCount(vector<int>& arr) {
        // code here
        int n=arr.size();
        unordered_map<int,int>freq;
        for(int x:arr){
            freq[x]++;
        }
        vector<int>ans;
        for(int i=1;i<=n;i++){
            ans.push_back(freq[i]);
        }
        return ans;
    }
};
